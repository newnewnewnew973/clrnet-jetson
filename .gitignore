# Official upstream source tree. Keep it outside this project commit.
/clrnet/

# Local caches and agent/tooling state.
/.git_repo/
/cache/
/.codex/
/.agents/
/.pytest_cache/
/tmp_trt_profile/
__pycache__/
*.py[cod]

# Large or machine-local runtime data.
/data/*
/weights/*
/clrnet_inference/data/*
/clrnet_inference/assets/images/*
!/clrnet_inference/assets/images/.gitkeep

# Model and TensorRT artifacts.
*.pth
*.pt
*.onnx
*.engine
*.trt
*.plan
*.zip

# Generated outputs. Keep the directory structure in the project, not results.
/clrnet_inference/outputs/**
!/clrnet_inference/outputs/
!/clrnet_inference/outputs/**/
!/clrnet_inference/outputs/.gitkeep
!/clrnet_inference/outputs/**/.gitkeep
/clrnet_tensorrt/outputs/**
!/clrnet_tensorrt/outputs/
!/clrnet_tensorrt/outputs/**/
!/clrnet_tensorrt/outputs/.gitkeep
!/clrnet_tensorrt/outputs/**/.gitkeep

# Native extension build products.
/clrnet_common/extensions/nms/build/
/clrnet_common/extensions/nms/*.so
*.egg-info/
.ninja_*
